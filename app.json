{
  "expo": {
    "name": "Smemorandum",
    "slug": "smemorandum",
    "description": "Smemorandum - Promemoria & Scadenze. Non dimenticare mai più compleanni, anniversari e scadenze importanti.",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C63FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smemorandum.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCalendarsUsageDescription": "Smemorandum needs calendar access to sync your events.",
        "NSContactsUsageDescription": "Smemorandum uses your contacts to import birthdays as reminders.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.smemorandum.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#6C63FF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": ["NOTIFICATIONS", "VIBRATE", "RECEIVE_BOOT_COMPLETED", "READ_CONTACTS"],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-localization",
      "expo-secure-store",
      "expo-contacts",
      ["react-native-android-widget", {
        "widgets": [
          {
            "name": "UpcomingEvents",
            "label": "Smemorandum",
            "description": "Prossimi eventi e compleanni",
            "minWidth": "256dp",
            "minHeight": "120dp",
            "targetCellWidth": 4,
            "targetCellHeight": 2,
            "maxResizeWidth": "400dp",
            "maxResizeHeight": "300dp",
            "resizeMode": "horizontal|vertical",
            "updatePeriodMillis": 1800000
          }
        ]
      }]
    ],
    "extra": {
      "eas": {
        "projectId": "your-project-id-here"
      }
    }
  }
}
